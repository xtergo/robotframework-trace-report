# Environment variables for Robot Framework integration tests.
# This file is consumed via --env-file by docker-compose.
# The real .env is generated by test/kind/itest-up.sh — do not edit it manually.

# Base URL for the trace-report server (port-forwarded from kind cluster)
TRACE_REPORT_BASE_URL=http://host.docker.internal:8077

# Kind cluster name (informational, used by itest.sh wrapper)
KIND_CLUSTER_NAME=trace-report-test

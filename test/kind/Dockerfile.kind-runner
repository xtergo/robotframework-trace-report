# Docker image with kind + kubectl for running Kind clusters.
# Mounts the host Docker socket to manage containers.
#
# Usage:
#   docker build -t kind-runner -f test/kind/Dockerfile.kind-runner .
#   docker run --rm -v /var/run/docker.sock:/var/run/docker.sock \
#       --network host kind-runner
FROM docker:27-cli

# Install kind and kubectl
RUN apk add --no-cache curl bash coreutils \
    && curl -Lo /usr/local/bin/kind https://kind.sigs.k8s.io/dl/v0.25.0/kind-linux-amd64 \
    && chmod +x /usr/local/bin/kind \
    && curl -Lo /usr/local/bin/kubectl \
       "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" \
    && chmod +x /usr/local/bin/kubectl

WORKDIR /workspace

# ---- Build stage ----
FROM python:3.11-slim AS builder

WORKDIR /build
COPY pyproject.toml README.md ./
COPY src/ src/

# Ensure latest pip, then install the package with MCP extras
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir --prefix=/install ".[mcp]"

# ---- Runtime stage ----
FROM python:3.11-slim

ARG GIT_SHA=dev

# Create non-root user (UID 10001)
RUN groupadd --gid 10001 appuser && \
    useradd --uid 10001 --gid 10001 --no-create-home --shell /usr/sbin/nologin appuser

# Copy only the installed package from builder
COPY --from=builder /install /usr/local

# Environment defaults
ENV PYTHONDONTWRITEBYTECODE="1" \
    PYTHONUNBUFFERED="1" \
    GIT_SHA="${GIT_SHA}"

EXPOSE 8080

# Switch to non-root user
USER 10001

ENTRYPOINT ["python", "-m", "rf_trace_viewer.mcp"]
CMD ["--transport", "stdio"]

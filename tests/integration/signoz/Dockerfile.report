FROM python:3.11-slim

WORKDIR /app

# Install dependencies first (cached layer)
COPY pyproject.toml ./
COPY src/ src/
RUN pip install --no-cache-dir -e .

ENV SIGNOZ_ENDPOINT=""
ENV SIGNOZ_API_KEY=""

EXPOSE 8077

CMD ["rf-trace-report", "serve", "--provider", "signoz", "--no-open", "--port", "8077"]

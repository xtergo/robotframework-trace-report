# Browser (Playwright) test runner for SigNoz integration UI validation
# Validates that the rf-trace-report live viewer correctly displays spans
# produced by the RF test runner.

FROM python:3.11-slim

# System deps for Playwright browsers + Node.js
RUN apt-get update && apt-get install -y \
    wget gnupg curl \
    libglib2.0-0 libnss3 libnspr4 libdbus-1-3 \
    libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxcb1 libxkbcommon0 libatspi2.0-0 libx11-6 \
    libxcomposite1 libxdamage1 libxext6 libxfixes3 \
    libxrandr2 libgbm1 libpango-1.0-0 libcairo2 libasound2 \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Python deps — all baked in, no dynamic pip install
RUN pip install --no-cache-dir \
    robotframework==7.1.1 \
    robotframework-browser==18.8.0

# Download Playwright browsers
RUN rfbrowser init

WORKDIR /tests

# Copy test suites into image
COPY tests/integration/signoz/browser_suites/ /tests/suites/

CMD ["robot", "--outputdir", "/tests/results", "/tests/suites/"]
